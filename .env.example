# AnyRouter 账号配置
ANYROUTER_ACCOUNTS=[{"name":"我的主账号","cookies":{"session":"你的session值"},"api_user":"你的api_user值"}]

# AgentRouter 账号配置（可选，格式与 ANYROUTER_ACCOUNTS 一致）
# 默认用 name 匹配 GitHub 账号；可加 github_login 显式指定 GitHub 用户名/邮箱
AGENTROUTER_ACCOUNTS=[{"name":"your_github_username","cookies":{"session":"xxx"},"api_user":"xxx"}]

# 可选：代理（AgentRouter 访问受限时使用）
# HTTP_PROXY=http://127.0.0.1:7890

# Claude 模型检查（复用 AGENTROUTER_ACCOUNTS + DINGDING_WEBHOOK，systemd timer 每30分钟检查）

# 可选：通知配置
# DINGDING_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_password
# EMAIL_TO=recipient@example.com
# PUSHPLUS_TOKEN=your_pushplus_token
# SERVERPUSHKEY=your_server_pushkey
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# WEIXIN_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
